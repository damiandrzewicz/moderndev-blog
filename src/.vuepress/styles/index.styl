img + em {
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

.post-preview-thumb{
    width: 100%;
    height: 160px;  
    overflow: hidden;
}

.post-preview-thumb img{
    max-width: 100%;
    
    display: block;

    margin-left: auto;
    margin-right: auto;
}

.theme-container.homepage {
  .hero {
    img {
        border-radius: 50%;
    }
    .description {
        font-size: 1.4rem;
    }
  }

}

figure {
    display: inline-block;
    text-align: center;
    width: 100%;
}
figure img {
    vertical-align: middle;
    display: inline-block;
}
figure figcaption {
    text-align: center;
    font-weight: bold;
}

.wrap-text-fig {
    display: block;
    float: left;
    text-align: center;
}

.wrap-text-cap {
    display: block;
}

h2, h3, h4, h5, h6 {
    color: #3eaf7c;
}