img + em {
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

.post-preview-thumb{
    width: 100%;
    height: 160px;  
    overflow: hidden;
}

.post-preview-thumb img{
    max-width: 100%;
    
    display: block;

    margin-left: auto;
    margin-right: auto;
}

.theme-container.homepage {
  .hero {
    img {
        border-radius: 50%;
    }
    .description {
        font-size: 1.4rem;
    }
  }

}

figure {
    display: inline-block;
    margin: 20px; /* adjust as needed */
}
figure img {
    vertical-align: top;
}
figure figcaption {
    text-align: center;
    font-weight: bold;
}