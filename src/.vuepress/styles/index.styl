img + em {
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

.post-preview-thumb{
    width: 100%;
    height: 150px;  
    overflow: hidden;
}

.post-preview-thumb img{
    max-width: 100%;
    
    display: block;

    margin-left: auto;
    margin-right: auto;

    transform: translateY(-50%);
}

.theme-container.homepage {
  .hero {
    img {
        border-radius: 50%;
    }
    .description {
        font-size: 1.4rem;
    }
  }

}

div[class*="language-"].line-numbers-mode .line-numbers-wrapper{
    line-height: 1.37;
}