img + em {
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

.post-preview-thumb{
    width: 100%;
    height: 130px;
    overflow: hidden;
}

.post-preview-thumb img{
    max-width: 100%;
    max-height: 100%;
    display: block;

    margin-left: auto;
    margin-right: auto;
}

.theme-container.homepage {
  .hero {
    img {
        border-radius: 50%;
    }
    .description {
        font-size: 1.4rem;
    }
  }

}